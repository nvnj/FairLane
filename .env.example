# Google / Gemini
GOOGLE_API_KEY=your_key_from_aistudio          # simpler for local dev
# OR Vertex (leave GOOGLE_API_KEY blank if using ADC)
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-3.5-flash                  # read from env, never hardcoded

# Arize Phoenix
PHOENIX_API_KEY=px_live_...
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name
PHOENIX_PROJECT_NAME=fairlane

# Escalation thresholds
ESCALATION_FLIP_THRESHOLD=0
ESCALATION_JUDGE_THRESHOLD=0.85
ESCALATION_TERMS_GAP_THRESHOLD=0.05
